{
  "appId": "com.localtranscribe.app",
  "productName": "LocalTranscribe",
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "directories": {
    "output": "../dist/packages",
    "buildResources": "../build"
  },
  "asar": true,
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../frontend/dist",
      "to": "frontend/dist",
      "filter": [
        "**/*"
      ]
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "../build/icon.ico",
    "extraResources": []
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": [
          "arm64"
        ]
      }
    ],
    "category": "public.app-category.productivity",
    "hardenedRuntime": true,
    "entitlements": "../build/entitlements.mac.plist",
    "entitlementsInherit": "../build/entitlements.mac.plist",
    "gatekeeperAssess": false,
    "extraResources": [
      {
        "from": "../backend/dist/macos-arm64/backend",
        "to": "backend/backend"
      },
      {
        "from": "../bin/macos-arm64",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      }
    ]
    ,
    "icon": "../build/icon.png"
  }
}
