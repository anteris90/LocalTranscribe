{
  "name": "localtranscribe-electron",
  "version": "0.1.8",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm --prefix .. run build:frontend && npm run build && electron .",
    "build": "node scripts/generate-icons.mjs && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pack:dir": "node scripts/generate-icons.mjs && electron-builder --dir --config electron-builder.json",
    "dist": "node scripts/verify-release-inputs.mjs && node scripts/generate-icons.mjs && electron-builder --config electron-builder.json"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "31.7.3",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.5",
    "typescript": "^5.6.3"
  }
}
